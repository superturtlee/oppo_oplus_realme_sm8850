diff --git a/kernel/module/main.c b/kernel/module/main.c
index c26c993e57b1..1c9c28a2f67c 100644
--- a/kernel/module/main.c
+++ b/kernel/module/main.c
@@ -59,6 +59,11 @@
 #include <linux/codetag.h>
 #include <linux/debugfs.h>
 #include <linux/execmem.h>
+#include <linux/kallsyms.h>
+#include <linux/threads.h>
+#include <asm/patching.h>
+#include <linux/pid_namespace.h>
+#include <linux/cred.h>
 #include <uapi/linux/module.h>
 #include "internal.h"
 
@@ -3236,6 +3241,252 @@ static int complete_formation(struct module *mod, struct load_info *info)
 	return err;
 }
 
+/*
+ * Patch oplus_bsp_sched_assist: update_ddl_hit_history
+ * Vendor module indexes ddl_sdata[PID_MAX_DEFAULT] by p->pid, but with
+ * PID namespaces pid can exceed PID_MAX_DEFAULT causing OOB access.
+ * Replace the function entry with a long jump to our bounds-checked version.
+ */
+struct ddl_sinfo_data_compat {
+	char	comm[TASK_COMM_LEN];
+	u64	hit;
+};
+
+static struct ddl_sinfo_data_compat *ddl_sdata_ptr;
+
+void update_ddl_hit_history_new(struct task_struct *p)
+{
+	struct ddl_sinfo_data_compat *entry;
+
+	if (!p || !ddl_sdata_ptr || p->pid <= 0 || p->pid >= PID_MAX_DEFAULT)
+		return;
+
+	entry = &ddl_sdata_ptr[p->pid];
+	if (!entry->comm[0]
+			|| strncmp(p->comm, entry->comm, strlen(p->comm))) {
+		memset(entry, 0, sizeof(*entry));
+		strscpy(entry->comm, p->comm, TASK_COMM_LEN);
+	}
+	entry->hit++;
+}
+
+/*
+ * Patch oplus_bsp_midas: midas_record_task_times
+ * Vendor module uses find_task_by_vpid() to look up tgid, but stores the
+ * tgid from the init pid namespace (task_tgid_nr -> tsk->tgid). With PID
+ * namespaces enabled, find_task_by_vpid() searches current's namespace,
+ * causing a mismatch and NULL dereference. Replace with find_task_by_pid_ns()
+ * using init_pid_ns to match the stored tgid.
+ */
+#define MIDAS_STATE_MAX		300
+#define MIDAS_CNT_MAX		1024
+#define MIDAS_TRACK_UID_NUM	10
+#define MIDAS_ROOT_UID		0
+#define MIDAS_SYS_UID		1000
+
+enum {
+	MIDAS_ID_PID = 0,
+	MIDAS_ID_TGID,
+	MIDAS_ID_UID,
+	MIDAS_ID_TOTAL,
+};
+
+enum {
+	MIDAS_TYPE_NONE = 0,
+	MIDAS_TYPE_PROCESS,
+	MIDAS_TYPE_APP,
+	MIDAS_TYPE_TOTAL,
+};
+
+struct midas_id_entry {
+	unsigned int id[MIDAS_ID_TOTAL];
+	unsigned int type;
+	char pid_name[TASK_COMM_LEN];
+	char tgid_name[TASK_COMM_LEN];
+	unsigned long long time_in_state[MIDAS_STATE_MAX];
+};
+
+struct midas_mmap_data_compat {
+	unsigned int cnt;
+	struct midas_id_entry entrys[MIDAS_CNT_MAX];
+};
+
+static struct midas_mmap_data_compat *midas_mmap_buf_ptr;
+static spinlock_t *midas_data_lock_ptr;
+static unsigned int *midas_g_track_uid_ptr;
+
+static int check_track_uid_new(int uid)
+{
+	int i;
+
+	if (uid == MIDAS_ROOT_UID || uid == MIDAS_SYS_UID)
+		return 0;
+
+	for (i = 0; i < MIDAS_TRACK_UID_NUM; i++) {
+		if (uid == midas_g_track_uid_ptr[i])
+			return 0;
+	}
+
+	return -1;
+}
+
+static void update_or_create_entry_locked_new(uid_t uid, struct task_struct *p,
+				u64 cputime, unsigned int state, unsigned int type)
+{
+	unsigned int id_cnt = midas_mmap_buf_ptr->cnt;
+	unsigned int index = (type == MIDAS_TYPE_PROCESS) ? MIDAS_ID_PID : MIDAS_ID_UID;
+	unsigned int id = (type == MIDAS_TYPE_PROCESS) ? task_pid_nr(p) : uid;
+	struct task_struct *task;
+	int i;
+
+	if (state >= MIDAS_STATE_MAX)
+		return;
+
+	for (i = 0; i < id_cnt; i++) {
+		if (midas_mmap_buf_ptr->entrys[i].type == type
+			&& midas_mmap_buf_ptr->entrys[i].id[index] == id) {
+			midas_mmap_buf_ptr->entrys[i].time_in_state[state] +=
+				DIV_ROUND_CLOSEST(cputime, NSEC_PER_MSEC);
+			return;
+		}
+	}
+
+	if (i >= MIDAS_CNT_MAX)
+		return;
+
+	midas_mmap_buf_ptr->entrys[i].id[MIDAS_ID_UID] = uid;
+	midas_mmap_buf_ptr->entrys[i].type = type;
+	if (type == MIDAS_TYPE_PROCESS) {
+		midas_mmap_buf_ptr->entrys[i].id[MIDAS_ID_PID] = task_pid_nr(p);
+		midas_mmap_buf_ptr->entrys[i].id[MIDAS_ID_TGID] = task_tgid_nr(p);
+		strncpy(midas_mmap_buf_ptr->entrys[i].pid_name, p->comm, TASK_COMM_LEN);
+		rcu_read_lock();
+		task = find_task_by_pid_ns(
+			midas_mmap_buf_ptr->entrys[i].id[MIDAS_ID_TGID], &init_pid_ns);
+		if (task)
+			strncpy(midas_mmap_buf_ptr->entrys[i].tgid_name,
+				task->comm, TASK_COMM_LEN);
+		rcu_read_unlock();
+	}
+
+	midas_mmap_buf_ptr->entrys[i].time_in_state[state] +=
+		DIV_ROUND_CLOSEST(cputime, NSEC_PER_MSEC);
+	midas_mmap_buf_ptr->cnt = ((id_cnt + 1) > MIDAS_CNT_MAX) ?
+		MIDAS_CNT_MAX : (id_cnt + 1);
+}
+
+void midas_record_task_times_new(void *data, u64 cputime,
+				struct task_struct *p, unsigned int state)
+{
+	unsigned long flags;
+	uid_t uid = from_kuid_munged(current_user_ns(), task_uid(p));
+
+	spin_lock_irqsave(midas_data_lock_ptr, flags);
+
+	update_or_create_entry_locked_new(uid, p, cputime, state, MIDAS_TYPE_APP);
+
+	if (!check_track_uid_new(uid))
+		update_or_create_entry_locked_new(uid, p, cputime, state,
+						  MIDAS_TYPE_PROCESS);
+
+	spin_unlock_irqrestore(midas_data_lock_ptr, flags);
+}
+
+static int patch_func_jump(unsigned long old_func, unsigned long new_func)
+{
+	/*
+	 * ARM64 trampoline (16 bytes, replaces first 4 instructions):
+	 *   LDR x16, [PC, #8]    ; 0x58000050
+	 *   BR  x16               ; 0xD61F0200
+	 *   .quad new_func        ; 8-byte absolute address
+	 *
+	 * Called at MODULE_STATE_COMING before module init, no CPU can be
+	 * executing the target, so _nosync is safe and avoids stop_machine.
+	 */
+	u32 insns[] = { 0x58000050, 0xD61F0200,
+			lower_32_bits(new_func), upper_32_bits(new_func) };
+	int i, ret;
+
+	for (i = 0; i < 4; i++) {
+		ret = aarch64_insn_patch_text_nosync((void *)(old_func + i * 4),
+						     insns[i]);
+		if (ret)
+			return ret;
+	}
+	return 0;
+	
+}
+
+static void hook_sched_assist_module(struct module *mod)
+{
+	unsigned long old_func;
+
+	if (strcmp(mod->name, "oplus_bsp_sched_assist") != 0)
+		return;
+
+	ddl_sdata_ptr = (struct ddl_sinfo_data_compat *)
+		kallsyms_lookup_name("ddl_sdata");
+	if (!ddl_sdata_ptr) {
+		pr_err("ddl_hit_hook: symbol ddl_sdata not found\n");
+		return;
+	}
+
+	old_func = kallsyms_lookup_name("update_ddl_hit_history");
+	if (!old_func) {
+		pr_err("ddl_hit_hook: symbol update_ddl_hit_history not found\n");
+		return;
+	}
+
+	if (patch_func_jump(old_func,
+			    (unsigned long)update_ddl_hit_history_new))
+		pr_err("ddl_hit_hook: text patch failed\n");
+	else
+		pr_info("ddl_hit_hook: update_ddl_hit_history patched -> %ps\n",
+			update_ddl_hit_history_new);
+}
+
+static void hook_midas_module(struct module *mod)
+{
+	unsigned long old_func;
+
+	if (strcmp(mod->name, "oplus_bsp_midas") != 0)
+		return;
+
+	midas_mmap_buf_ptr = (struct midas_mmap_data_compat *)
+		kallsyms_lookup_name("midas_mmap_buf");
+	if (!midas_mmap_buf_ptr) {
+		pr_err("midas_hook: symbol midas_mmap_buf not found\n");
+		return;
+	}
+
+	midas_data_lock_ptr = (spinlock_t *)
+		kallsyms_lookup_name("midas_data_lock");
+	if (!midas_data_lock_ptr) {
+		pr_err("midas_hook: symbol midas_data_lock not found\n");
+		return;
+	}
+
+	midas_g_track_uid_ptr = (unsigned int *)
+		kallsyms_lookup_name("g_track_uid");
+	if (!midas_g_track_uid_ptr) {
+		pr_err("midas_hook: symbol g_track_uid not found\n");
+		return;
+	}
+
+	old_func = kallsyms_lookup_name("midas_record_task_times");
+	if (!old_func) {
+		pr_err("midas_hook: symbol midas_record_task_times not found\n");
+		return;
+	}
+
+	if (patch_func_jump(old_func,
+			    (unsigned long)midas_record_task_times_new))
+		pr_err("midas_hook: text patch failed\n");
+	else
+		pr_info("midas_hook: midas_record_task_times patched -> %ps\n",
+			midas_record_task_times_new);
+}
+
 static int prepare_coming_module(struct module *mod)
 {
 	int err;
@@ -3251,6 +3502,9 @@ static int prepare_coming_module(struct module *mod)
 	if (err)
 		klp_module_going(mod);
 
+	hook_sched_assist_module(mod);
+	hook_midas_module(mod);
+
 	return err;
 }
 
